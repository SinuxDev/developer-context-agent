{
  "name": "developer-context-agent",
  "version": "0.2.0",
  "description": "Local context agent for AI assistants — hybrid retrieval, token-budgeted context packs, MCP server",
  "license": "MIT",
  "keywords": ["mcp", "context-engineering", "cursor", "ai-agent", "codebase"],
  "repository": {
    "type": "git",
    "url": "https://github.com/SinuxDev/developer-context-agent.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-agent": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "mcp": "tsx src/cli/main.ts mcp",
    "context-agent": "tsx src/cli/main.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@vscode/ripgrep": "^1.15.11",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.39.3",
    "fastify": "^5.2.1",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.2",
    "js-tiktoken": "^1.0.19",
    "openai": "^4.85.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "simple-git": "^3.27.0",
    "ts-morph": "^25.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.21.0",
    "prettier": "^3.5.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
