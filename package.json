{
  "name": "developer-context-agent",
  "version": "0.1.0",
  "description": "Token-efficient, codebase-aware AI agent runtime for developer workflows",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "mcp": "tsx src/mcp/server.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@vscode/ripgrep": "^1.15.11",
    "drizzle-orm": "^0.39.3",
    "fastify": "^5.2.1",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.2",
    "js-tiktoken": "^1.0.19",
    "openai": "^4.85.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "simple-git": "^3.27.0",
    "ts-morph": "^25.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.21.0",
    "prettier": "^3.5.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
