PORT=3100
DATABASE_URL=postgres://dca:dca@localhost:5433/developer_context_agent
REDIS_URL=redis://localhost:6379

# Local context agent (MCP / CLI) — no Docker required
REPO_PATH=
TOKEN_BUDGET_DEFAULT=8000
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: HTTP server + LLM adapters (legacy supervised runs)
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=groq:llama-3.3-70b-versatile
PLANNER_MODEL=groq:llama-3.1-8b-instant
ALLOWED_REPO_ROOTS=
API_KEY=dev-key
LOG_LEVEL=info
NODE_ENV=development
